generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(uuid())
  name            String
  email           String          @unique
  emailVerified   Boolean         @default(false)
  image           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  language        String          @default("en")
  accounts        Account[]
  createdInvites  InviteToken[]   @relation("CreatedInvites")
  ownedProperties Property[]      @relation("PropertyOwner")
  staffProperties PropertyStaff[]
  sessions        Session[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Property {
  id           String          @id @default(uuid())
  name         String
  address      String?
  ownerId      String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  archivedAt   DateTime?       @db.Timestamptz(6)
  currency     String          @default("IDR")
  expenses     Expense[]
  inviteTokens InviteToken[]
  owner        User            @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  staff        PropertyStaff[]
  rooms        Room[]
  tenants      Tenant[]

  @@map("property")
}

model PropertyStaff {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@map("property_staff")
}

model Room {
  id          String     @id @default(uuid())
  propertyId  String
  roomNumber  String
  roomType    String?
  monthlyRent Decimal    @db.Decimal(12, 2)
  status      RoomStatus @default(AVAILABLE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  archivedAt  DateTime?
  capacity    Int        @default(1)
  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants     Tenant[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId, status])
  @@map("room")
}

model Tenant {
  id            String          @id @default(uuid())
  propertyId    String
  roomId        String?
  name          String
  phone         String?
  email         String?
  movedInAt     DateTime        @default(now())
  movedOutAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  billing_cycle billing_cycle[]
  payments      Payment[]
  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room          Room?           @relation(fields: [roomId], references: [id])
  notes         TenantNote[]

  @@index([propertyId, movedOutAt])
  @@map("tenant")
}

model Payment {
  id             String         @id @default(uuid())
  tenantId       String
  amount         Decimal        @db.Decimal(12, 2)
  paymentDate    DateTime       @db.Date
  createdAt      DateTime       @default(now())
  billingCycleId String?
  billing_cycle  billing_cycle? @relation(fields: [billingCycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, paymentDate])
  @@map("payment")
}

model Expense {
  id          String          @id @default(uuid())
  propertyId  String
  date        DateTime        @db.Date
  category    ExpenseCategory
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, date])
  @@map("expense")
}

model TenantNote {
  id        String   @id @default(uuid())
  tenantId  String
  date      DateTime @db.Date
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
  @@map("tenant_note")
}

model InviteToken {
  id         String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  token      String     @unique
  email      String
  role       InviteRole
  propertyId String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdBy  String
  createdAt  DateTime   @default(now())
  creator    User       @relation("CreatedInvites", fields: [createdBy], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property   Property?  @relation(fields: [propertyId], references: [id], onUpdate: NoAction)

  @@index([createdBy])
  @@index([token])
  @@map("invite_token")
}

model Currency {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  code      String   @unique
  locale    String
  label     String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("currency")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model billing_cycle {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId  String
  year      Int
  month     Int
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment   Payment[]

  @@unique([tenantId, year, month])
  @@index([tenantId])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  RENOVATION
}

enum ExpenseCategory {
  ELECTRICITY
  WATER
  INTERNET
  MAINTENANCE
  CLEANING
  SUPPLIES
  TAX
  TRANSFER
  OTHER
}

enum InviteRole {
  owner
  staff
}

enum invite_role {
  owner
  staff
}
