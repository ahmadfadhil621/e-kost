# Database (Supabase PostgreSQL)
# Use the pooled connection (port 6543, Transaction mode) for runtime app queries
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE"
# Use the direct connection (port 5432, Session mode) for Prisma schema commands (db pull, db push)
# Same credentials as DATABASE_URL, just change the port from 6543 → 5432
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Dev-only features (comma-separated emails; leave unset = no restriction)
# DEV_EMAILS=""
